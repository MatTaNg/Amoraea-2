@@ -390,6 +390,22 @@ public class AVManager implements LifecycleEventListener, AudioManager.OnAudioFo
   }
 
   private void updatePlaySoundThroughEarpiece(boolean playThroughEarpiece) {
+    // After recording/voice routing, Bluetooth SCO or communication device can keep output on earpiece-like path.
+    if (!playThroughEarpiece) {
+      try {
+        mAudioManager.stopBluetoothSco();
+        mAudioManager.setBluetoothScoOn(false);
+      } catch (Exception e) {
+        Log.w("ExpoAV", "updatePlaySoundThroughEarpiece bluetooth reset", e);
+      }
+      if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.S) {
+        try {
+          mAudioManager.clearCommunicationDevice();
+        } catch (Exception e) {
+          Log.w("ExpoAV", "clearCommunicationDevice", e);
+        }
+      }
+    }
     mAudioManager.setMode(playThroughEarpiece ? AudioManager.MODE_IN_COMMUNICATION : AudioManager.MODE_NORMAL);
     mAudioManager.setSpeakerphoneOn(!playThroughEarpiece);
   }
