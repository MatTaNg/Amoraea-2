{
  "name": "amoraea",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package",
    "eas-build-post-install": "node scripts/verify-expo-av-patch.js",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:tunnel": "expo start --web --tunnel",
    "build:web": "expo export -p web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:maestro": "maestro test maestro",
    "db:push": "supabase db push",
    "db:push:all": "supabase db push --include-all --yes",
    "reprocess-style-labels": "npx tsx --env-file=.env scripts/reprocess-style-labels.node.ts",
    "reprocess-style-labels:deno": "deno run --allow-net --allow-env --allow-read scripts/reprocess-style-labels.ts",
    "reprocess-narrative-conceptual": "npx tsx --env-file=.env scripts/reprocess-narrative-conceptual-from-transcripts.node.ts",
    "reprocess-narrative-conceptual:deno": "deno run --allow-net --allow-env --allow-read scripts/reprocess-narrative-conceptual-from-transcripts.ts",
    "reprocess-moment5-scores": "npx tsx --env-file=.env scripts/reprocess-moment5-scores.ts",
    "recompute-pillar-scores": "npx tsx --env-file=.env scripts/recompute-pillar-scores-from-stored-slices.ts",
    "audit-narrative-conceptual-extremes": "deno run --allow-net --allow-env --allow-read scripts/audit-narrative-conceptual-extremes.ts",
    "test:communication-style": "jest --testPathPattern=interviewStyleMarkers --no-cache",
    "deploy:fn:analyze-interview-text": "npx supabase functions deploy analyze-interview-text",
    "deploy:fn:analyze-interview-audio": "npx supabase functions deploy analyze-interview-audio",
    "deploy:fn:admin-delete-user": "npx supabase functions deploy admin-delete-user",
    "deploy:fn:communication-style": "npx supabase functions deploy analyze-interview-text && npx supabase functions deploy analyze-interview-audio"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^3.3.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "expo": "~54.0.0",
    "expo-audio": "~1.1.1",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "libphonenumber-js": "^1.12.41",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.49.2",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native-community/cli": "latest",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.11",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "patch-package": "^8.0.0",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.33.5",
    "supabase": "^2.84.7",
    "typescript": "^5.3.3"
  },
  "private": true
}
